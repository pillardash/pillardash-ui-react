{
  "name": "pillardash-ui-react",
  "version": "0.1.141",
  "type": "module",
  "description": "Pillardash reusable react components",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.mjs",
  "types": "dist/index.d.ts",
  "style": "dist/styles.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.mjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build:js && npm run build:styles",
    "build:js": "rollup -c --bundleConfigAsCjs",
    "build:styles": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --config ./tailwind.package.config.cjs --minify",
    "dev": "rollup -c -w",
    "prepublishOnly": "npm run build",
    "release": "npm version patch && npm publish && git push origin HEAD && git push --tags",
    "pub": "npm version patch && npm publish",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "typescript",
    "pillardash"
  ],
  "author": "mrprotocoll",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrprotocoll/pillardash-ui-react.git"
  },
  "homepage": "https://github.com/mrprotocoll/pillardash-ui-react#readme",
  "peerDependencies": {
    "@tiptap/extension-image": ">=3",
    "@tiptap/extension-link": ">=3",
    "@tiptap/extension-underline": ">=3",
    "@tiptap/react": ">=3",
    "@tiptap/starter-kit": ">=3",
    "lucide-react": ">=0.400.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@tiptap/extension-image": {
      "optional": true
    },
    "@tiptap/extension-link": {
      "optional": true
    },
    "@tiptap/extension-underline": {
      "optional": true
    },
    "@tiptap/react": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    }
  },
  "dependencies": {
    "classnames": "^2.3.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.1.5",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/react": "^10.0.0",
    "@storybook/react-vite": "^10.2.10",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-image": "^3.0.7",
    "@tiptap/extension-link": "^3.0.7",
    "@tiptap/extension-table": "^3.22.5",
    "@tiptap/extension-table-cell": "^3.22.5",
    "@tiptap/extension-table-header": "^3.22.5",
    "@tiptap/extension-table-row": "^3.22.5",
    "@tiptap/extension-task-item": "^3.22.5",
    "@tiptap/extension-task-list": "^3.22.5",
    "@tiptap/extension-text-align": "^3.22.5",
    "@tiptap/extension-underline": "^3.0.7",
    "@tiptap/react": "^3.0.7",
    "@tiptap/starter-kit": "^3.0.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.3",
    "lucide-react": "^0.511.0",
    "rollup": "^4.9.0",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "storybook": "^10.0.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3"
  }
}
